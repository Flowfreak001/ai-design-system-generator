# Provided by Railway in production; set locally for dev.
DATABASE_URL="postgresql://user:password@localhost:5433/adsg?schema=public"
# Optional. When empty, background jobs run inline instead of via BullMQ/Redis.
REDIS_URL=""
# Added later, for real AI agents. Never commit the real value.
OPENAI_API_KEY=""

# Strongest available OpenAI vision-capable (understanding, NOT image-generation)
# model for reference screenshot analysis. Must be a text/reasoning model that
# accepts images — never gpt-image / chatgpt-image (those are for generation).
# If the configured model isn't available on the account, the code auto-falls
# back to gpt-4o at runtime.
REFERENCE_VISION_MODEL="gpt-5.5"
REFERENCE_BLUEPRINT_MODEL="gpt-5.5"
REFERENCE_VISION_MAX_TOKENS="12000"
REFERENCE_BLUEPRINT_MAX_TOKENS="12000"
# If gpt-5.5 isn't in your API project, set these to gpt-4o (the code also
# auto-falls back to gpt-4o at runtime — never to gpt-4o-mini).
#
# AI reference-image → section generation is ADMIN/INTERNAL ONLY. Normal users
# get the controlled manual Section Library (browse → preview → add). Set this
# to "true" to reveal the admin AI reference panel + debug output. Leave unset
# (or anything other than "true") to hide all AI reference UI from users.
ENABLE_REFERENCE_AI_ADMIN="false"
# Session signing secret (generate with: openssl rand -hex 32)
AUTH_SECRET=""

# Optional: point the reference-site crawler at a remote browser (e.g. browserless)
# instead of a locally-installed Chromium. Most reliable on PaaS.
# PLAYWRIGHT_WS_ENDPOINT="wss://chrome.browserless.io?token=..."

# Wix "Publish to Wix (test)" — single-account API-key auth for the CMS write.
# WIX_API_KEY: create in the Wix dashboard → API Key Manager (never commit the real value).
# WIX_SITE_ID: the Site ID of your Wix site.
# WIX_COLLECTION_ID: target Data collection (defaults to "Services" if unset).
WIX_API_KEY=""
WIX_SITE_ID=""
WIX_COLLECTION_ID="Services"

# Wix App OAuth — lets each user connect their OWN Wix account (Settings → Connect Wix).
# From your Wix app's OAuth page (dev.wix.com). Callback must match the app's Redirect URL.
WIX_APP_ID=""
WIX_APP_SECRET=""
WIX_APP_CALLBACK_URL="http://localhost:3000/api/integrations/wix/callback"
