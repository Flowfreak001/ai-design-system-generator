# Provided by Railway in production; set locally for dev.
DATABASE_URL="postgresql://user:password@localhost:5433/adsg?schema=public"
# Optional. When empty, background jobs run inline instead of via BullMQ/Redis.
REDIS_URL=""
# Added later, for real AI agents. Never commit the real value.
OPENAI_API_KEY=""

# Strongest available OpenAI vision-capable (understanding, NOT image-generation)
# model for reference screenshot analysis. Must be a text/reasoning model that
# accepts images — never gpt-image / chatgpt-image (those are for generation).
# If the configured model isn't available on the account, the code auto-falls
# back to gpt-4o at runtime.
REFERENCE_VISION_MODEL="gpt-5.5"
REFERENCE_BLUEPRINT_MODEL="gpt-5.5"
REFERENCE_VISION_MAX_TOKENS="12000"
REFERENCE_BLUEPRINT_MAX_TOKENS="12000"
# Session signing secret (generate with: openssl rand -hex 32)
AUTH_SECRET=""

# Optional: point the reference-site crawler at a remote browser (e.g. browserless)
# instead of a locally-installed Chromium. Most reliable on PaaS.
# PLAYWRIGHT_WS_ENDPOINT="wss://chrome.browserless.io?token=..."
