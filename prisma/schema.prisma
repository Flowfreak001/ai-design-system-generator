// Agency Project OS + Small Business Automation Builder — data model
// Prisma 7 (prisma-client generator → ESM client in src/generated/prisma)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------
// Tenancy: Agency → Users, Businesses (clients), Projects
// ---------------------------------------------------------------

model Agency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  businesses Business[]
  projects   Project[]
}

model Business {
  id           String   @id @default(cuid())
  agencyId     String
  name         String
  type         String? // plumber, restaurant, real estate, taxi, clinic…
  website      String?
  contactName  String?
  contactEmail String?
  stage        String   @default("Onboarding") // Onboarding | Active | Paused | Completed
  services     String[] @default([]) // e.g. SEO, PPC, Web Design, Automation
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency   Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  projects Project[]
  leads    Lead[]

  @@index([agencyId])
}

model User {
  id           String   @id @default(cuid())
  agencyId     String?
  name         String?
  email        String   @unique
  passwordHash String?
  role         String   @default("agency_owner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency        Agency?        @relation(fields: [agencyId], references: [id])
  savedSections SavedSection[]
}

// A section a user bookmarked from the library. Stores the built-in section id
// plus a metadata snapshot (name, category) so the saved list renders without
// re-resolving the catalog.
model SavedSection {
  id        String   @id @default(cuid())
  userId    String
  sectionId String
  name      String
  category  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
}

// ---------------------------------------------------------------
// Projects
// ---------------------------------------------------------------

enum ProjectType {
  WEBSITE_APP
  AUTOMATION_WORKFLOW
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  DELIVERED
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  agencyId    String?
  businessId  String?
  name        String
  clientName  String?
  type        ProjectType   @default(WEBSITE_APP)
  status      ProjectStatus @default(DRAFT)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  agency    Agency?         @relation(fields: [agencyId], references: [id])
  business  Business?       @relation(fields: [businessId], references: [id])
  inputs    ProjectInput[]
  files     GeneratedFile[]
  agentRuns AgentRun[]
  notes     ProjectNote[]
  workflows Workflow[]

  @@index([status])
  @@index([type])
}

// Structured inputs, grouped by category (e.g. "brief", "automation").
model ProjectInput {
  id        String   @id @default(cuid())
  projectId String
  category  String
  data      Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ---------------------------------------------------------------
// Generated artifacts + versions
// ---------------------------------------------------------------

model GeneratedFile {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String   @default("markdown")
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions FileVersion[]

  @@unique([projectId, name])
  @@index([projectId])
}

model FileVersion {
  id        String   @id @default(cuid())
  fileId    String
  version   Int
  content   String   @db.Text
  createdAt DateTime @default(now())

  file GeneratedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, version])
  @@index([fileId])
}

// ---------------------------------------------------------------
// Agent runs (AI pipeline activity, mock for now)
// ---------------------------------------------------------------

model AgentRun {
  id        String   @id @default(cuid())
  projectId String
  name      String
  status    String   @default("completed")
  input     Json?
  output    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  steps   AgentStep[]

  @@index([projectId])
}

model AgentStep {
  id        String   @id @default(cuid())
  runId     String
  title     String
  status    String   @default("completed")
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// ---------------------------------------------------------------
// Notes & decisions
// ---------------------------------------------------------------

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ---------------------------------------------------------------
// Workflow foundation (automation projects)
// ---------------------------------------------------------------

enum WorkflowNodeType {
  TRIGGER
  AI_CLASSIFY
  CONDITION
  CREATE_LEAD
  CREATE_TASK
  SEND_EMAIL
  HUMAN_APPROVAL
  END
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  WAITING_APPROVAL
  COMPLETED
  FAILED
}

model Workflow {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes   WorkflowNode[]
  edges   WorkflowEdge[]
  runs    WorkflowRun[]

  @@index([projectId])
}

model WorkflowNode {
  id         String           @id @default(cuid())
  workflowId String
  type       WorkflowNodeType
  title      String
  config     Json?
  position   Json? // { order } now; { x, y } for a visual builder later
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowEdge {
  id         String   @id @default(cuid())
  workflowId String
  sourceId   String
  targetId   String
  label      String? // e.g. "Yes" / "No" off a CONDITION
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowRun {
  id         String            @id @default(cuid())
  workflowId String
  status     WorkflowRunStatus @default(PENDING)
  input      Json?
  output     Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  workflow  Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps     WorkflowStep[]
  approvals Approval[]

  @@index([workflowId])
  @@index([status])
}

model WorkflowStep {
  id        String   @id @default(cuid())
  runId     String
  nodeId    String?
  title     String
  status    String
  detail    String?
  input     Json?
  output    Json?
  createdAt DateTime @default(now())

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model Approval {
  id        String   @id @default(cuid())
  runId     String
  title     String
  content   String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
}

// ---------------------------------------------------------------
// Leads (small-business side)
// ---------------------------------------------------------------

model Lead {
  id         String   @id @default(cuid())
  businessId String
  name       String?
  email      String?
  phone      String?
  source     String?
  status     String   @default("new")
  summary    String?
  data       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

// ---------------------------------------------------------------
// Section Library — global, reusable catalog of admin/custom sections
// (built-in sections stay in code; forks/custom/ai-drafts live here).
// Agency-scoped so it's shared across all of an agency's projects.
// ---------------------------------------------------------------

model LibrarySection {
  id            String   @id @default(cuid())
  agencyId      String?
  name          String
  slug          String
  category      String   @default("custom")
  layoutType    String   @default("custom")
  componentName String   @default("")
  sourceType    String   @default("custom") // built-in | custom | forked | ai-draft
  status        String   @default("draft") // draft | ready | archived
  visibility    String   @default("public") // admin-only | public
  codeMode      String   @default("studio-tsx") // built-in | studio-tsx | html-css
  tsxCode       String?  @db.Text
  config        Json?
  defaultContent Json?
  editableFields String[] @default([])
  tags          String[] @default([])
  originality   String   @default("")
  version       Int      @default(1)
  history       Json? // [{ code, at }]
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agencyId, status])
}
