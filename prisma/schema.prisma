// AI Website Design System Generator — data model
// Prisma 7 (prisma-client generator → ESM client in src/generated/prisma)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A design-system generation project for a client/business.
model Project {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  clientName   String?
  businessName String?
  businessType String?
  status       ProjectStatus @default(DRAFT)

  input     ProjectInput?
  files     GeneratedFile[]
  agentRuns AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// The structured brief captured on project creation (1:1 with Project).
model ProjectInput {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  websiteGoal         String?
  targetAudience      String?
  existingWebsiteUrl  String?
  referenceUrls       String[] @default([])
  competitorUrls      String[] @default([])
  brandColors         String[] @default([])
  requiredPages       String[] @default([])
  servicesProducts    String?
  seoKeywords         String[] @default([])
  platformTarget      String?
  animationPreference String?
  notes               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A generated output artifact (BRAND.md, DESIGN.md, ...).
model GeneratedFile {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName String
  fileType FileType   @default(MARKDOWN)
  content  String     @db.Text
  status   FileStatus @default(READY)
  version  Int        @default(1)

  versions FileVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, fileName])
  @@index([projectId])
}

// Historical versions of a generated file.
model FileVersion {
  id              String        @id @default(cuid())
  generatedFileId String
  generatedFile   GeneratedFile @relation(fields: [generatedFileId], references: [id], onDelete: Cascade)

  version    Int
  content    String  @db.Text
  changeNote String?

  createdAt DateTime @default(now())

  @@unique([generatedFileId, version])
  @@index([generatedFileId])
}

// A run of the (mock) multi-agent generation pipeline for a project.
model AgentRun {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status      RunStatus @default(QUEUED)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?

  steps AgentStep[]

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([status])
}

// A single agent's step within an AgentRun.
model AgentStep {
  id         String   @id @default(cuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  agentName String
  status    StepStatus @default(PENDING)
  input     Json?
  output    Json?
  error     String?

  startedAt   DateTime?
  completedAt DateTime?

  @@index([agentRunId])
}

enum ProjectStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum FileType {
  MARKDOWN
  JSON
  CSS
  HTML
  PROMPT
}

enum FileStatus {
  DRAFT
  GENERATING
  READY
  STALE
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum StepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
